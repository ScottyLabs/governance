+// RedactEvent replaces a previously-sent event with an empty body so the bridges drop
+// the relayed copy from Slack/Discord.
+func (c *Client) RedactEvent(roomID, eventID, reason string) error {
+	txnID, err := randomTxnID()
+	if err != nil {
+		return err
+	}
+	path := fmt.Sprintf(
+		"/_matrix/client/v3/rooms/%s/redact/%s/%s",
+		url.PathEscape(roomID),
+		url.PathEscape(eventID),
+		url.PathEscape(txnID),
+	)
+	return c.request(http.MethodPut, path, redactRequest{Reason: reason}, nil)
+}
