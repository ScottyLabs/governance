+// pollPortalStatus re-inspects the portal until predicate is satisfied or timeout elapses.
+func (c *Client) pollPortalStatus(roomID, slackChannelID, discordChannelID string, timeout, interval time.Duration, predicate func(PortalBridgeStatus) bool) (PortalBridgeStatus, error) {
+	deadline := time.Now().Add(timeout)
+	var (
+		status PortalBridgeStatus
+		err    error
+	)
+	for {
+		status, err = c.InspectPortalBridgeStatus(roomID, slackChannelID, discordChannelID)
+		if err == nil && predicate(status) {
+			return status, nil
+		}
+		if time.Now().After(deadline) {
+			if err != nil {
+				return status, err
+			}
+			return status, fmt.Errorf("timed out after %s", timeout)
+		}
+		time.Sleep(interval)
+	}
+}
