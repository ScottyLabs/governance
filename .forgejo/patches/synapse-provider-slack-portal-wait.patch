+// bridgeSlackIntoPortal invites and waits for the Slack bridge bot, issues `!slack bridge`,
+// then blocks until the m.bridge state event lands or the poll deadline expires.
+func (c *Client) bridgeSlackIntoPortal(roomID, slackChannelID, discordChannelID string) (PortalBridgeStatus, error) {
+	status := PortalBridgeStatus{}
+	if err := c.InviteUser(roomID, c.slackBotID); err != nil {
+		return status, fmt.Errorf("invite slack bot: %w", err)
+	}
+	if err := c.MakeRoomAdmin(roomID, c.slackBotID); err != nil {
+		return status, fmt.Errorf("promote slack bot in portal room: %w", err)
+	}
+	if err := c.WaitForUserJoined(roomID, c.slackBotID, bridgeBotJoinTimeout, bridgePollInterval); err != nil {
+		return status, fmt.Errorf("slack bot join: %w", err)
+	}
+	chatID := c.slackChatID(slackChannelID)
+	var slackCmd string
+	if c.slackRelayLogin != "" {
+		slackCmd = fmt.Sprintf("%s bridge %s %s %s", c.slackPrefix, c.slackRelayLogin, chatID, slackBridgeFlags)
+	} else {
+		slackCmd = fmt.Sprintf("%s bridge %s %s", c.slackPrefix, chatID, slackBridgeFlags)
+	}
+	eventID, err := c.SendRoomMessage(roomID, slackCmd)
+	if err != nil {
+		return status, fmt.Errorf("slack bridge: %w", err)
+	}
+	// `!slack bridge ... <login> <chat> --overwrite` sets the relay login as a side effect
+	// when a login is supplied, so no separate set-relay command is issued.
+	status, err = c.pollPortalStatus(roomID, slackChannelID, discordChannelID, bridgePollTimeout, bridgePollInterval, func(s PortalBridgeStatus) bool {
+		return s.SlackBridged
+	})
+	if err != nil {
+		return status, fmt.Errorf(
+			"slack bridge did not connect chat %s into %s within %s: %w (verify the Slack login %s is a member of the Slack channel and that the bridge bot %s has joined)",
+			chatID, roomID, bridgePollTimeout, err, c.slackRelayLogin, c.slackBotID,
+		)
+	}
+	if eventID != "" {
+		// Redacting locally tells the slack bridge to delete the relayed message in
+		// the Slack channel. Failures are ignored because the bridge state is already
+		// correct and any leftover text in Slack is cosmetic.
+		_ = c.RedactEvent(roomID, eventID, "bridge command")
+	}
+	return status, nil
+}
