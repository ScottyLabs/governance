+// IsUserJoined reports whether userID is currently in the joined-members list for roomID.
+func (c *Client) IsUserJoined(roomID, userID string) (bool, error) {
+	path := fmt.Sprintf("/_matrix/client/v3/rooms/%s/joined_members", url.PathEscape(roomID))
+	var resp joinedMembersResponse
+	if err := c.request(http.MethodGet, path, nil, &resp); err != nil {
+		return false, err
+	}
+	_, ok := resp.Joined[userID]
+	return ok, nil
+}
+
+// WaitForUserJoined polls until userID appears in roomID's joined members or timeout elapses.
+// mautrix-go's command parser only fires on messages received live after the bot joins,
+// so callers MUST wait for the bot before sending bridge commands or they vanish into history.
+func (c *Client) WaitForUserJoined(roomID, userID string, timeout, interval time.Duration) error {
+	deadline := time.Now().Add(timeout)
+	for {
+		joined, err := c.IsUserJoined(roomID, userID)
+		if err == nil && joined {
+			return nil
+		}
+		if time.Now().After(deadline) {
+			if err != nil {
+				return fmt.Errorf("waiting for %s to join %s: %w", userID, roomID, err)
+			}
+			return fmt.Errorf("%s did not join %s within %s", userID, roomID, timeout)
+		}
+		time.Sleep(interval)
+	}
 }
 
