{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TeamFile",
  "type": "object",
  "properties": {
    "team": {
      "$ref": "#/$defs/Team"
    }
  },
  "required": [
    "team"
  ],
  "$defs": {
    "Channel": {
      "type": "object",
      "properties": {
        "discord": {
          "type": [
            "string",
            "null"
          ]
        },
        "slack": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "DocsType": {
      "type": "string",
      "enum": [
        "starlight",
        "rust",
        "openapi"
      ]
    },
    "Feature": {
      "type": "string",
      "enum": [
        "kennel",
        "sentry",
        "oidc_client",
        "admin_client"
      ]
    },
    "Project": {
      "type": "object",
      "properties": {
        "channels": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Channel"
          }
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "figma_projects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "leads": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "members": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "repos": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Repo"
          }
        },
        "slug": {
          "type": "string"
        }
      },
      "required": [
        "slug",
        "name"
      ]
    },
    "Repo": {
      "type": "object",
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "docs": {
          "type": "boolean",
          "default": true
        },
        "docs_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocsType"
            },
            {
              "type": "null"
            }
          ]
        },
        "export_command": {
          "type": [
            "string",
            "null"
          ]
        },
        "features": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Feature"
          }
        },
        "name": {
          "type": "string"
        },
        "openapi_spec": {
          "type": [
            "string",
            "null"
          ]
        },
        "topics": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "visibility": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepoVisibility"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name"
      ]
    },
    "RepoVisibility": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ]
    },
    "Team": {
      "type": "object",
      "properties": {
        "channels": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Channel"
          }
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "figma_projects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "leads": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "members": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "projects": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Project"
          }
        },
        "repos": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Repo"
          }
        },
        "slug": {
          "type": "string"
        }
      },
      "required": [
        "slug",
        "name"
      ]
    }
  }
}