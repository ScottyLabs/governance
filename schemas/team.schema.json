{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TeamFile",
  "type": "object",
  "properties": {
    "team": {
      "$ref": "#/$defs/Team"
    }
  },
  "required": [
    "team"
  ],
  "$defs": {
    "AiGatewayFeature": {
      "type": "object",
      "properties": {
        "dev_max_parallel_requests": {
          "description": "Concurrent in-flight requests for the shared non-prod key",
          "type": "integer",
          "format": "int64",
          "default": 20
        },
        "dev_monthly_budget": {
          "description": "Monthly budget in USD for the key shared by staging, preview, and dev",
          "type": "number",
          "format": "double",
          "default": 5.0
        },
        "dev_rpm_limit": {
          "description": "Requests per minute for the shared non-prod key",
          "type": "integer",
          "format": "int64",
          "default": 200
        },
        "dev_tpm_limit": {
          "description": "Tokens per minute for the shared non-prod key",
          "type": "integer",
          "format": "int64",
          "default": 1000000
        },
        "prod_max_parallel_requests": {
          "description": "Concurrent in-flight requests for the prod key",
          "type": "integer",
          "format": "int64",
          "default": 100
        },
        "prod_monthly_budget": {
          "description": "Monthly budget in USD for the prod key",
          "type": "number",
          "format": "double",
          "default": 20.0
        },
        "prod_rpm_limit": {
          "description": "Requests per minute for the prod key",
          "type": "integer",
          "format": "int64",
          "default": 1000
        },
        "prod_tpm_limit": {
          "description": "Tokens per minute for the prod key",
          "type": "integer",
          "format": "int64",
          "default": 4000000
        }
      },
      "additionalProperties": false
    },
    "CdnFeature": {
      "type": "object",
      "additionalProperties": false
    },
    "Channel": {
      "type": "object",
      "properties": {
        "discord": {
          "type": [
            "string",
            "null"
          ]
        },
        "slack": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "DocsFeature": {
      "type": "object",
      "additionalProperties": false
    },
    "Features": {
      "description": "A feature is enabled by its presence, an empty table enables it with defaults",
      "type": "object",
      "properties": {
        "ai_gateway": {
          "anyOf": [
            {
              "$ref": "#/$defs/AiGatewayFeature"
            },
            {
              "type": "null"
            }
          ]
        },
        "cdn": {
          "anyOf": [
            {
              "$ref": "#/$defs/CdnFeature"
            },
            {
              "type": "null"
            }
          ]
        },
        "docs": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocsFeature"
            },
            {
              "type": "null"
            }
          ]
        },
        "kennel": {
          "anyOf": [
            {
              "$ref": "#/$defs/KennelFeature"
            },
            {
              "type": "null"
            }
          ]
        },
        "oidc_client": {
          "anyOf": [
            {
              "$ref": "#/$defs/OidcClientFeature"
            },
            {
              "type": "null"
            }
          ]
        },
        "posthog": {
          "anyOf": [
            {
              "$ref": "#/$defs/PosthogFeature"
            },
            {
              "type": "null"
            }
          ]
        },
        "sentry": {
          "anyOf": [
            {
              "$ref": "#/$defs/SentryFeature"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "KennelFeature": {
      "type": "object",
      "additionalProperties": false
    },
    "OidcClientFeature": {
      "type": "object",
      "properties": {
        "admin": {
          "description": "Also provision a Keycloak admin client with realm-management access",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "PosthogFeature": {
      "type": "object",
      "additionalProperties": false
    },
    "Project": {
      "type": "object",
      "properties": {
        "channels": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Channel"
          }
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "figma_projects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "leads": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "members": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "public_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "repos": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Repo"
          }
        },
        "slug": {
          "type": "string"
        }
      },
      "required": [
        "slug",
        "name"
      ]
    },
    "Repo": {
      "type": "object",
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "features": {
          "$ref": "#/$defs/Features",
          "default": {
            "ai_gateway": null,
            "cdn": null,
            "docs": null,
            "kennel": null,
            "oidc_client": null,
            "posthog": null,
            "sentry": null
          }
        },
        "name": {
          "type": "string"
        },
        "topics": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "visibility": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepoVisibility"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name"
      ]
    },
    "RepoVisibility": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ]
    },
    "SentryFeature": {
      "type": "object",
      "properties": {
        "platform": {
          "description": "Sentry platform slug for the project, e.g. \"rust\" or \"python\"",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "Team": {
      "type": "object",
      "properties": {
        "channels": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Channel"
          }
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "figma_projects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "leads": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "members": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "projects": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Project"
          }
        },
        "public_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "repos": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/Repo"
          }
        },
        "slug": {
          "type": "string"
        }
      },
      "required": [
        "slug",
        "name"
      ]
    }
  }
}