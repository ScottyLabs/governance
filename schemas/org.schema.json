{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrgFile",
  "type": "object",
  "properties": {
    "org": {
      "$ref": "#/$defs/OrgConfig"
    }
  },
  "required": [
    "org"
  ],
  "$defs": {
    "CommunicationConfig": {
      "type": "object",
      "properties": {
        "channels": {
          "description": "Org-wide channels that are not owned by a team (e.g. open-source, merch, finance).\nSet both `slack` and `discord` to bridge via Matrix.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/OrgChannel"
          }
        },
        "discord_guild_id": {
          "type": "string"
        },
        "discord_hub_channel_id": {
          "type": "string"
        },
        "discord_leads_channel_id": {
          "type": "string"
        },
        "matrix_account_required": {
          "description": "When true, governance validate checks that each team member has a Matrix account.",
          "type": "boolean",
          "default": false
        },
        "matrix_domain": {
          "type": "string"
        },
        "matrix_homeserver_url": {
          "type": "string"
        },
        "slack_hub_channel_id": {
          "type": "string"
        },
        "slack_leads_channel_id": {
          "type": "string"
        },
        "slack_team_id": {
          "description": "Slack workspace ID (e.g. T03EVH29W) for mautrix-slack bridge chat IDs.",
          "type": "string"
        },
        "slack_workspace": {
          "type": "string"
        }
      },
      "required": [
        "discord_guild_id",
        "discord_hub_channel_id",
        "discord_leads_channel_id",
        "slack_workspace",
        "slack_team_id",
        "slack_hub_channel_id",
        "slack_leads_channel_id",
        "matrix_domain",
        "matrix_homeserver_url"
      ]
    },
    "FigmaConnection": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "org_id": {
          "type": "string"
        }
      },
      "required": [
        "org_id"
      ]
    },
    "ForgejoConfig": {
      "type": "object",
      "properties": {
        "org": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "org"
      ]
    },
    "GithubConfig": {
      "type": "object",
      "properties": {
        "org": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "org"
      ]
    },
    "GoogleGroupsConnection": {
      "type": "object",
      "properties": {
        "admin": {
          "type": "string"
        },
        "ops": {
          "type": "string"
        },
        "tech": {
          "type": "string"
        }
      },
      "required": [
        "admin",
        "ops",
        "tech"
      ]
    },
    "KeycloakConnection": {
      "type": "object",
      "properties": {
        "dev_redirect_uri": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        },
        "redirect_uri": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "realm",
        "redirect_uri",
        "dev_redirect_uri"
      ]
    },
    "OrgChannel": {
      "type": "object",
      "properties": {
        "discord": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "slack": {
          "type": [
            "string",
            "null"
          ]
        },
        "slug": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "slug"
      ]
    },
    "OrgConfig": {
      "type": "object",
      "properties": {
        "communication": {
          "anyOf": [
            {
              "$ref": "#/$defs/CommunicationConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "defaults": {
          "$ref": "#/$defs/OrgDefaults",
          "default": {
            "allow_merge_commit": false,
            "allow_rebase_merge": true,
            "allow_squash_merge": true,
            "default_branch": "main",
            "repo_visibility": "public",
            "required_approvals": 1
          }
        },
        "figma": {
          "anyOf": [
            {
              "$ref": "#/$defs/FigmaConnection"
            },
            {
              "type": "null"
            }
          ]
        },
        "forgejo": {
          "anyOf": [
            {
              "$ref": "#/$defs/ForgejoConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "github": {
          "anyOf": [
            {
              "$ref": "#/$defs/GithubConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "google_groups": {
          "anyOf": [
            {
              "$ref": "#/$defs/GoogleGroupsConnection"
            },
            {
              "type": "null"
            }
          ]
        },
        "keycloak": {
          "anyOf": [
            {
              "$ref": "#/$defs/KeycloakConnection"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "tech_director": {
          "type": "string"
        },
        "vaultwarden": {
          "anyOf": [
            {
              "$ref": "#/$defs/VaultwardenConnection"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "tech_director"
      ]
    },
    "OrgDefaults": {
      "type": "object",
      "properties": {
        "allow_merge_commit": {
          "type": "boolean"
        },
        "allow_rebase_merge": {
          "type": "boolean"
        },
        "allow_squash_merge": {
          "type": "boolean"
        },
        "default_branch": {
          "type": "string"
        },
        "repo_visibility": {
          "$ref": "#/$defs/RepoVisibility"
        },
        "required_approvals": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "repo_visibility",
        "default_branch",
        "allow_squash_merge",
        "allow_merge_commit",
        "allow_rebase_merge",
        "required_approvals"
      ]
    },
    "RepoVisibility": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ]
    },
    "VaultwardenConnection": {
      "type": "object",
      "properties": {
        "org_id": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "org_id"
      ]
    }
  }
}