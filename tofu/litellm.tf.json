{
  "resource": {
    "litellm_key": {
      "collie_dev": {
        "budget_duration": "monthly",
        "key_alias": "collie-dev",
        "max_budget": 5.0,
        "max_parallel_requests": 20,
        "metadata": {
          "project": "collie"
        },
        "rpm_limit": 200,
        "team_id": "${litellm_team.devops.id}",
        "tpm_limit": 1000000
      },
      "collie_prod": {
        "budget_duration": "monthly",
        "key_alias": "collie-prod",
        "max_budget": 20.0,
        "max_parallel_requests": 100,
        "metadata": {
          "project": "collie"
        },
        "rpm_limit": 1000,
        "team_id": "${litellm_team.devops.id}",
        "tpm_limit": 4000000
      }
    },
    "litellm_team": {
      "devops": {
        "blocked": false,
        "team_alias": "devops",
        "team_member_permissions": []
      }
    },
    "vault_kv_secret_v2": {
      "collie_dev_litellm_api_key": {
        "data_json": "${jsonencode({ value = litellm_key.collie_dev.key })}",
        "mount": "secret",
        "name": "secretspec/collie/dev/LITELLM_API_KEY"
      },
      "collie_dev_litellm_base_url": {
        "data_json": "${jsonencode({ value = var.litellm_url })}",
        "mount": "secret",
        "name": "secretspec/collie/dev/LITELLM_BASE_URL"
      },
      "collie_preview_litellm_api_key": {
        "data_json": "${jsonencode({ value = litellm_key.collie_dev.key })}",
        "mount": "secret",
        "name": "secretspec/collie/preview/LITELLM_API_KEY"
      },
      "collie_preview_litellm_base_url": {
        "data_json": "${jsonencode({ value = var.litellm_url })}",
        "mount": "secret",
        "name": "secretspec/collie/preview/LITELLM_BASE_URL"
      },
      "collie_prod_litellm_api_key": {
        "data_json": "${jsonencode({ value = litellm_key.collie_prod.key })}",
        "mount": "secret",
        "name": "secretspec/collie/prod/LITELLM_API_KEY"
      },
      "collie_prod_litellm_base_url": {
        "data_json": "${jsonencode({ value = var.litellm_url })}",
        "mount": "secret",
        "name": "secretspec/collie/prod/LITELLM_BASE_URL"
      },
      "collie_staging_litellm_api_key": {
        "data_json": "${jsonencode({ value = litellm_key.collie_dev.key })}",
        "mount": "secret",
        "name": "secretspec/collie/staging/LITELLM_API_KEY"
      },
      "collie_staging_litellm_base_url": {
        "data_json": "${jsonencode({ value = var.litellm_url })}",
        "mount": "secret",
        "name": "secretspec/collie/staging/LITELLM_BASE_URL"
      }
    }
  }
}