{
  "locals": {
    "devops_devenv_mirror_data": {
      "interval": "8h0m0s",
      "remote_address": "git@github.com:ScottyLabs/devenv.git",
      "sync_on_commit": true,
      "use_ssh": true
    },
    "devops_governance_mirror_data": {
      "interval": "8h0m0s",
      "remote_address": "git@github.com:ScottyLabs/governance.git",
      "sync_on_commit": true,
      "use_ssh": true
    },
    "devops_infrastructure_mirror_data": {
      "interval": "8h0m0s",
      "remote_address": "git@github.com:ScottyLabs/infrastructure.git",
      "sync_on_commit": true,
      "use_ssh": true
    },
    "devops_kennel_mirror_data": {
      "interval": "8h0m0s",
      "remote_address": "git@github.com:ScottyLabs/kennel.git",
      "sync_on_commit": true,
      "use_ssh": true
    }
  },
  "resource": {
    "restapi_object": {
      "devops_devenv_push_mirror": {
        "data": "${jsonencode(local.devops_devenv_mirror_data)}",
        "depends_on": [
          "forgejo_repository.devops_devenv"
        ],
        "id_attribute": "remote_name",
        "path": "/api/v1/repos/ScottyLabs/devenv/push_mirrors"
      },
      "devops_governance_push_mirror": {
        "data": "${jsonencode(local.devops_governance_mirror_data)}",
        "depends_on": [
          "forgejo_repository.devops_governance"
        ],
        "id_attribute": "remote_name",
        "path": "/api/v1/repos/ScottyLabs/governance/push_mirrors"
      },
      "devops_infrastructure_push_mirror": {
        "data": "${jsonencode(local.devops_infrastructure_mirror_data)}",
        "depends_on": [
          "forgejo_repository.devops_infrastructure"
        ],
        "id_attribute": "remote_name",
        "path": "/api/v1/repos/ScottyLabs/infrastructure/push_mirrors"
      },
      "devops_kennel_push_mirror": {
        "data": "${jsonencode(local.devops_kennel_mirror_data)}",
        "depends_on": [
          "forgejo_repository.devops_kennel"
        ],
        "id_attribute": "remote_name",
        "path": "/api/v1/repos/ScottyLabs/kennel/push_mirrors"
      }
    }
  }
}